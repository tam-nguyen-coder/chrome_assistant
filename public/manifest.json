{
    "manifest_version": 3,
    "name": "LLM Assistant",
    "version": "1.0.0",
    "description": "Personal AI assistant powered by your own LLM API (Anthropic/OpenAI compatible)",
    "permissions": [
        "sidePanel",
        "storage",
        "contextMenus",
        "activeTab"
    ],
    "side_panel": {
        "default_path": "src/sidepanel/sidepanel.html"
    },
    "options_page": "src/options/options.html",
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "action": {
        "default_title": "LLM Assistant"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}